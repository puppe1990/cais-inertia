# Server
PORT=:8080
ENV=development
APP_URL=http://localhost:8080
LOCALE=en

# Database
DB_PATH=./data/app.db

# Security (required when ENV=production)
ADMIN_TOKEN=

# Reverse proxy (comma-separated IPs; trust X-Forwarded-For for client IP)
TRUSTED_PROXIES=

# SMTP (optional; password reset emails — logs to stdout when unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
