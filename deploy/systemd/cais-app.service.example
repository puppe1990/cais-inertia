[Unit]
Description=MyApp (Cais)
After=network.target

[Service]
Type=exec
User=root
Group=root
WorkingDirectory=/opt/myapp/current
EnvironmentFile=/etc/myapp/env
ExecStart=/opt/myapp/current/bin/server
Restart=always
RestartSec=5
MemoryMax=192M
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
